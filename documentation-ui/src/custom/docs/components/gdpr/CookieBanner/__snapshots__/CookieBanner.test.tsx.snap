             and 
            <a
              class="font-semibold hover:underline underline-offset-4"
              href="https://www.quantinuum.com/privacy"
              rel="noopener noreferrer"
              target="_blank"
            >
              Privacy Notice
            </a>
            . For details, including the list of cookies, purposes, vendors and retention periods, please read our 
            <a
              class="font-semibold hover:underline underline-offset-4"
              href="https://www.quantinuum.com/cookie-notice"
              rel="noopener noreferrer"
              target="_blank"
            >
              Cookie Policy
            </a>
            .
          </p>
          <div
            class="flex flex-col md:hidden"
          >
            <div
              class="flex mb-4 gap-4"
            >
              <button
                aria-label="button"
                class="w-full"
                variant="secondary"
              >
                Required Only
              </button>
              <button
                aria-label="button"
                class="w-full"
              >
                Accept All
              </button>
            </div>
            <button
              aria-label="button"
              class="w-full"
              variant="outline"
            >
              Manage Preferences
            </button>
          </div>
          <div
            class="hidden md:block w-3/12"
          >
            <div
              class="flex flex-col gap-3"
            >
              <button
                aria-label="button"
                class="w-full"
              >
                Accept All
              </button>
              <div
                class="flex md:flex-col lg:flex-row gap-3"
              >
                <button
                  aria-label="button"
                  variant="secondary"
                >
                  Required Only
                </button>
                <button
                  aria-label="button"
                  variant="outline"
                >
                  Preferences
